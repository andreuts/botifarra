{
  "name": "@botifarra/server",
  "version": "0.0.1",
  "description": "Botifarra backend — Fastify + Colyseus",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@botifarra/core": "workspace:*",
    "@botifarra/shared": "workspace:*",
    "@colyseus/core": "^0.15.57",
    "@colyseus/schema": "^2.0.37",
    "@colyseus/ws-transport": "^0.15.3",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.3",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.8.2",
    "argon2": "^0.43.0",
    "colyseus": "^0.15.30",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
