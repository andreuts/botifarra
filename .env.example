# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. Neon pooler URL with ?sslmode=require)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Strong random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-value

# Your production origin — must match exactly (no trailing slash)
# Use your custom domain if you have one, otherwise the Oracle VM public IP
CORS_ORIGIN=https://yourdomain.com

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Upstash connection URL — use the rediss:// (TLS) endpoint
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ─── Admin ───────────────────────────────────────────────────────────────────
# Secret key for /admin/* endpoints — generate with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-strong-random-value

# ─── Optional ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
