{
  "name": "botifarra",
  "private": true,
  "version": "0.0.1",
  "description": "Botifarra Online — Catalan card game multiplayer platform",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors cyan,magenta --names server,web \"pnpm --filter @botifarra/server dev\" \"pnpm --filter @botifarra/web dev\"",
    "dev:server": "pnpm --filter @botifarra/server dev",
    "dev:web": "pnpm --filter @botifarra/web dev",
    "db:up": "docker compose up -d",
    "db:migrate": "pnpm --filter @botifarra/server db:migrate",
    "db:generate": "pnpm --filter @botifarra/server db:generate",
    "setup": "docker compose up -d && pnpm --filter @botifarra/server db:migrate",
    "build": "pnpm -r build",
    "build:all": "pnpm -w -r build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma",
      "msgpackr-extract"
    ]
  }
}
